@model SocialMediaApp.Models.Campaign

@{
    ViewData["Title"] = "Create Campaign";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card card-acs">
                <div class="card-body p-4">
                    <h4 class="mb-2 fw-bold"><i class="bi bi-megaphone text-acs-teal me-2"></i>Create Social Campaign</h4>
                    <p class="text-muted small mb-4">
                        Fill in the details below to start your social awareness movement.
                    </p>

                    <form asp-action="Create" method="post" id="create-campaign-form">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-semibold">Campaign Title</label>
                            <input asp-for="Title" class="form-control" placeholder="e.g. Clean Water for All" required />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Describe the purpose and impact of your campaign..."></textarea>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ImpactGoal" class="form-label fw-semibold">Impact Goal</label>
                            <input asp-for="ImpactGoal" class="form-control" placeholder="e.g. 5,000 signatures or $10k raised" />
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-acs-teal">
                                <i class="bi bi-check2 me-1"></i>Submit for Approval
                            </button>
                            <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
