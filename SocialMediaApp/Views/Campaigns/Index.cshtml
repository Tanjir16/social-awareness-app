@model IEnumerable<SocialMediaApp.Models.Campaign>

@{
    ViewData["Title"] = "Social Campaigns";
}

<div class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <h3 class="mb-0 fw-bold"><i class="bi bi-megaphone text-acs-teal me-2"></i>Social Campaigns</h3>
        <a asp-action="Create" class="btn btn-acs-teal">
            <i class="bi bi-plus-lg me-1"></i>New Campaign
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card card-acs">
            <div class="card-body text-center py-5">
                <div class="feature-icon teal mx-auto mb-3"><i class="bi bi-megaphone"></i></div>
                <h5 class="fw-bold">No campaigns yet</h5>
                <p class="text-muted mb-3">Be the first to create a social awareness campaign.</p>
                <a asp-action="Create" class="btn btn-acs-teal">Create Campaign</a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var c in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card card-acs h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title mb-0 fw-bold">@c.Title</h5>
                                <span class="badge @(c.Status == "Active" ? "badge-acs-active" : c.Status == "Approved" ? "badge-acs-approved" : "badge-acs-pending")">@c.Status</span>
                            </div>
                            <p class="card-text small text-muted mb-2">@(string.IsNullOrEmpty(c.Description) ? "" : c.Description.Length > 120 ? c.Description.Substring(0, 120) + "…" : c.Description)</p>
                            <div class="small text-muted">
                                <i class="bi bi-bullseye me-1"></i>Goal: @c.ImpactGoal
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
