@{
    ViewData["Title"] = "Login";
}

<div class="auth-wrap">
    <div class="card auth-card">
        <div class="card-body">
            <h4 class="mb-2 text-center fw-bold">Welcome back</h4>
            <p class="text-muted small text-center mb-4">
                Log in to access your dashboard, campaigns, and business ads.
            </p>

            @if (ViewData["Error"] is string error && !string.IsNullOrWhiteSpace(error))
            {
                <div class="alert alert-danger py-2 small mb-3">@error</div>
            }

            <form asp-action="Login" method="post">
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                <div class="mb-3">
                    <label class="form-label">Email address</label>
                    <input name="email" type="email" class="form-control" placeholder="you@example.com" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input name="password" type="password" class="form-control" placeholder="Enter your password" required />
                </div>

                <button type="submit" class="btn btn-acs-teal w-100 mb-3 py-2">Log In</button>

                <div class="text-center small text-muted">
                    Don't have an account? <a asp-action="Register">Create one</a>
                </div>
            </form>
        </div>
    </div>
</div>
