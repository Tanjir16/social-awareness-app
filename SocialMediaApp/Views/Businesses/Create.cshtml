@model SocialMediaApp.Models.Business

@{
    ViewData["Title"] = "Create Business Ad";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card card-acs">
                <div class="card-body p-4">
                    <h4 class="mb-2 fw-bold"><i class="bi bi-shop text-acs-orange me-2"></i>Create Business Ad</h4>
                    <p class="text-muted small mb-4">
                        Promote your business in the community directory.
                    </p>

                    <form asp-action="Create" method="post">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold">Business Name</label>
                            <input asp-for="Name" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Industry" class="form-label fw-semibold">Industry</label>
                            <input asp-for="Industry" class="form-control" placeholder="e.g. Retail, Services" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Website" class="form-label fw-semibold">Website</label>
                            <input asp-for="Website" class="form-control" placeholder="https://example.com" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="City" class="form-label fw-semibold">City</label>
                            <input asp-for="City" class="form-control" />
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-acs-orange">
                                <i class="bi bi-check2 me-1"></i>Save
                            </button>
                            <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
