@model IEnumerable<SocialMediaApp.Models.Business>

@{
    ViewData["Title"] = "Small Business Directory";
}

<div class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <h3 class="mb-0 fw-bold"><i class="bi bi-shop text-acs-orange me-2"></i>Small Business Directory</h3>
        <a asp-action="Create" class="btn btn-acs-orange">
            <i class="bi bi-plus-lg me-1"></i>Add Business Ad
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card card-acs">
            <div class="card-body text-center py-5">
                <div class="feature-icon orange mx-auto mb-3"><i class="bi bi-shop"></i></div>
                <h5 class="fw-bold">No businesses listed yet</h5>
                <p class="text-muted mb-3">Add your business to the directory.</p>
                <a asp-action="Create" class="btn btn-acs-orange">Add Business</a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var b in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card card-acs h-100">
                        <div class="card-body">
                            <h5 class="card-title fw-bold mb-2">@b.Name</h5>
                            <div class="text-muted small mb-2">
                                <i class="bi bi-tag me-1"></i>@b.Industry
                            </div>
                            @if (!string.IsNullOrWhiteSpace(b.City))
                            {
                                <div class="small mb-1"><i class="bi bi-geo-alt me-1"></i>@b.City</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(b.Website))
                            {
                                <a href="@b.Website" target="_blank" rel="noopener" class="small text-acs-teal text-decoration-none">
                                    <i class="bi bi-link-45deg me-1"></i>Visit website
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
