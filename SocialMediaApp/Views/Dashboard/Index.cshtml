@model SocialMediaApp.Controllers.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container py-4">
    <div class="row">
        <div class="col-lg-8 mb-4">
            <div class="card card-acs dashboard-welcome mb-4">
                <div class="card-body d-flex align-items-center flex-wrap gap-3">
                    <div class="avatar-initial">
                        @Model.User.FullName.First()
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mb-1 fw-bold">Hi, @Model.User.FullName</h4>
                        <p class="text-muted mb-0">Manage your impact and visibility today.</p>
                    </div>
                    <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-acs-teal btn-sm">
                        <i class="bi bi-box-arrow-right me-1"></i>Logout
                    </a>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <a asp-controller="Campaigns" asp-action="Create" class="text-decoration-none">
                        <div class="card card-acs-teal h-100">
                            <div class="card-body d-flex align-items-center">
                                <div class="me-3 fs-2"><i class="bi bi-megaphone"></i></div>
                                <div class="flex-grow-1">
                                    <h5 class="card-title mb-1">Create Social Campaign</h5>
                                    <p class="small mb-0 opacity-90">Start a new awareness movement.</p>
                                </div>
                                <i class="bi bi-chevron-right fs-4"></i>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-md-6">
                    <a asp-controller="Businesses" asp-action="Create" class="text-decoration-none">
                        <div class="card card-acs-orange h-100">
                            <div class="card-body d-flex align-items-center">
                                <div class="me-3 fs-2"><i class="bi bi-cursor"></i></div>
                                <div class="flex-grow-1">
                                    <h5 class="card-title mb-1">Create Business Ad</h5>
                                    <p class="small mb-0 opacity-90">Promote your business to the community.</p>
                                </div>
                                <i class="bi bi-chevron-right fs-4"></i>
                            </div>
                        </div>
                    </a>
                </div>
            </div>

            <div class="card card-acs mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="section-title mb-0">My Campaigns</h5>
                        <a asp-controller="Campaigns" asp-action="Index" class="small">View all</a>
                    </div>
                    @if (!Model.MyCampaigns.Any())
                    {
                        <p class="text-muted small mb-0">You haven't created any campaigns yet.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var c in Model.MyCampaigns)
                            {
                                <li class="list-group-item px-0 border-0 border-bottom">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <div class="fw-semibold">@c.Title</div>
                                            <div class="text-muted small">@c.ImpactGoal</div>
                                        </div>
                                        <span class="badge @(c.Status == "Active" ? "badge-acs-active" : c.Status == "Approved" ? "badge-acs-approved" : "badge-acs-pending")">@c.Status</span>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>

            <div class="card card-acs">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="section-title mb-0">My Business Ads</h5>
                        <a asp-controller="Businesses" asp-action="Index" class="small">View directory</a>
                    </div>
                    @if (!Model.MyBusinesses.Any())
                    {
                        <p class="text-muted small mb-0">You haven't created any business ads yet.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var b in Model.MyBusinesses)
                            {
                                <li class="list-group-item px-0 border-0 border-bottom">
                                    <div class="fw-semibold">@b.Name</div>
                                    <div class="text-muted small">@b.Industry</div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card card-acs mb-3">
                <div class="card-body">
                    <h6 class="text-uppercase text-muted small mb-3">My Profile</h6>
                    <div class="fw-semibold">@Model.User.FullName</div>
                    <div class="text-muted small">@Model.User.Email</div>
                </div>
            </div>

            <div class="card card-acs">
                <div class="card-body">
                    <h6 class="text-uppercase text-muted small mb-3">Quick Links</h6>
                    <ul class="list-unstyled small mb-0">
                        <li class="mb-2"><a asp-controller="Campaigns" asp-action="Index" class="text-acs-teal text-decoration-none"><i class="bi bi-megaphone me-2"></i>Social Campaigns Grid</a></li>
                        <li class="mb-2"><a asp-controller="Businesses" asp-action="Index" class="text-acs-teal text-decoration-none"><i class="bi bi-shop me-2"></i>Small Business Directory</a></li>
                        <li><a asp-controller="Feed" asp-action="Index" class="text-acs-teal text-decoration-none"><i class="bi bi-chat-dots me-2"></i>Community Feed</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
